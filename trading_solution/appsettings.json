{
  // List of products to subscribe to.  These identifiers must match those
  // published by the venues.  Additional tenors can be added here.
  "Products": [
    "EURIBOR-3M",
    "EURIBOR-6M"
  ],
  // Venue connection settings.  Host and port correspond to each
  // console service.  UpdateIntervalMs is informational; the server
  // uses its own internal cadence but the client may choose to display it.
  "Venues": {
    "Venue_A": {
      "Host": "127.0.0.1",
      "Port": 5001,
      "UpdateIntervalMs": 200
    },
    "Venue_B": {
      "Host": "127.0.0.1",
      "Port": 5002,
      "UpdateIntervalMs": 350
    },
    "Venue_C": {
      "Host": "127.0.0.1",
      "Port": 5003,
      "UpdateIntervalMs": 500
    }
  },
  // Number of milliseconds after which a quote is considered stale and
  // ignored when computing the best bid/ask.  Stale venues are grayed
  // out in the UI.
  "StaleMs": 5000
}